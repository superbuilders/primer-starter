# Copy this file to .env and fill in your publishable key.
#   cp .env.example .env

# Public origin of your app (used for client-side absolute URLs).
VITE_APP_URL=http://localhost:5173

# Origin of the Primer deployment to talk to. Leave as-is unless you're
# pointing at a custom Primer instance.
VITE_PRIMER_ORIGIN=https://primerlearn.dev

# Your publishable key from primerlearn.dev → Keys (starts with `pk_`).
VITE_PRIMER_PUBLISHABLE_KEY=pk_replace_me
