# Copy this file to .env.local and fill in values for local development.
# Or run `bunx vercel env pull .env.local` after `bunx vercel link` to pull
# values from Vercel.
#
# Server-only vars are validated in src/env.ts under `server`.
# Public vars must be prefixed with NEXT_PUBLIC_ and listed under `client`.

# Public origin of the app. Used in metadata and any client-side absolute URLs.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Primer adaptive learning runtime — fully client-side.
# Origin of the Primer deployment to talk to.
NEXT_PUBLIC_PRIMER_ORIGIN=https://sb-primer.vercel.app
# Public Primer frontend key (pk_...). Identifies the Primer frontend; not
# learner auth. The SDK pairs this with a learner access token, which it
# resolves via SDK-managed browser auth inside create() unless an
# accessToken is passed explicitly.
NEXT_PUBLIC_PRIMER_PUBLISHABLE_KEY=pk_replace_me
