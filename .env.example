# Copy this file to .env.local and fill in values for local development.
# Or run `bunx vercel env pull .env.local` after `bunx vercel link` to pull
# values from Vercel.
#
# Server-only vars are validated in src/env.ts under `server`.
# Public vars must be prefixed with NEXT_PUBLIC_ and listed under `client`.

# Public origin of the app. Used in metadata and any client-side absolute URLs.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Primer adaptive learning runtime — server-only.
# Origin of the Primer deployment to talk to.
PRIMER_ORIGIN=https://sb-primer.vercel.app
# Frontend secret key (sk_...). Mints short-lived browser access tokens.
# Never expose this to the client. Pull from Vercel for prod.
PRIMER_SECRET_KEY=sk_replace_me
# Hard-coded "verified" learner email for this no-auth starter. In a real
# integration, this would come from your authenticated user record after
# email verification — see src/lib/primer/get-token.ts.
PRIMER_TEST_EMAIL=test@example.com
